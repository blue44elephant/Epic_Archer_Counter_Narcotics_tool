# Epic Archer Configuration Template
# Copy this file to .env and fill in your actual credentials

# Copernicus Data Space (Satellite Imagery)
# Get from: https://dataspace.copernicus.eu/
# Instructions in README.md Step 1a
COPERNICUS_CLIENT_ID=your-client-id-here
COPERNICUS_CLIENT_SECRET=your-client-secret-here

# AISStream (Real-time Ship Data)
# Get from: https://www.aisstream.io/
# Instructions in README.md Step 1b
AISSTREAM_API_KEY=your-aisstream-key-here

# OpenSky (Aircraft Tracking - Optional)
# Get from: https://opensky-network.org/
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Data Storage
EPIC_ARCHER_DATA_DIR=./epic_archer_data

# ML Model Path
RF_MODEL_PATH=./rf_model.pickle
